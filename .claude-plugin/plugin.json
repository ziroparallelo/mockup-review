{
  "name": "mockup-review",
  "version": "0.2.0",
  "description": "Interactive HTML mockup review framework. Generate side-by-side variant mockups, collect user decisions in-browser (click/textarea), live-reload when Claude updates files, and send feedback back to Claude with a single button click.",
  "author": {
    "name": "Alessandro Buccini",
    "email": "alebuccini2@gmail.com"
  },
  "homepage": "https://github.com/ziroparallelo/mockup-review",
  "repository": "https://github.com/ziroparallelo/mockup-review",
  "license": "MIT",
  "keywords": [
    "mockup",
    "client-review",
    "visual-review",
    "design-feedback",
    "astro",
    "web-design",
    "claude-code"
  ],
  "commands": [
    "commands/mockup-init.md",
    "commands/mockup-serve.md",
    "commands/mockup-stop.md",
    "commands/client-revision.md"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/inject-decisions-context.py"
          }
        ]
      }
    ]
  }
}